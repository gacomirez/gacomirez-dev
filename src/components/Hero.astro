---
export interface Props {
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaLink?: string;
}

const { title, subtitle, ctaText, ctaLink } = Astro.props;
---

<section class="hero">
  <div class="hero__content container">
    <h1 class="hero__title animate-fade-in-up">{title}</h1>
    <p class="hero__subtitle animate-fade-in-up" style="animation-delay: 100ms">{subtitle}</p>
    {ctaText && ctaLink && (
      <a href={ctaLink} class="hero__cta animate-fade-in-up" style="animation-delay: 200ms">{ctaText}</a>
    )}
  </div>
</section>

<style>
  .hero {
    background: var(--color-hero-gradient);
    padding-block: var(--space-3xl);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-hero-glow-primary) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -10%;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-hero-glow-accent) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    position: relative;
    z-index: 1;
  }

  .hero__title {
    font-size: var(--font-size-3xl);
    color: var(--color-text);
    max-width: 640px;
  }

  .hero__subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-muted);
    max-width: 560px;
    line-height: 1.6;
  }

  .hero__cta {
    display: inline-block;
    padding: var(--space-sm) var(--space-xl);
    background-color: var(--color-primary);
    color: white;
    font-weight: 600;
    border-radius: var(--radius);
    transition: background-color var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .hero__cta:hover {
    background-color: var(--color-primary-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
  }

  @media (max-width: 640px) {
    .hero {
      padding-block: var(--space-2xl);
    }

    .hero__title {
      font-size: var(--font-size-2xl);
    }

    .hero__subtitle {
      font-size: var(--font-size-base);
    }

    .hero::before,
    .hero::after {
      display: none;
    }
  }
</style>
